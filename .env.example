# Luno API credentials (from https://www.luno.com/wallet/security/api)
LUNO_API_KEY=your_api_key_id_here
LUNO_API_SECRET=your_api_key_secret_here

# Logging level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Path to the Hyperliquid momentum scanner output directory
# (the directory that contains all_rankings.csv / scan_summary.json)
HL_SCANNER_OUTPUT_DIR=../hyperliquid-momentum-scanner/output

# Override config file location (default: config.yaml)
# CONFIG_FILE=config.yaml
